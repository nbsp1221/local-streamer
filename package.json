{
  "name": "local-streamer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "backfill:browser-playback-fixtures": "bun scripts/backfill-browser-compatible-playback.ts --video-id 68e5f819-15e8-41ef-90ee-8a96769311b7 --video-id 754c6828-621c-4df6-9cf8-a3d77297b85a",
    "dev": "react-router dev",
    "download:ffmpeg": "bash scripts/download-ffmpeg.sh",
    "download:shaka": "bash scripts/download-shaka-packager.sh",
    "init-data": "node scripts/init-data.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun ./build/server/index.js",
    "test": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file ./scripts/run-vitest.ts && LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file run test:smoke:dev-auth && LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file run test:smoke:bun-auth",
    "test:integration": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file ./scripts/run-vitest.ts run --project integration",
    "test:legacy": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file ./scripts/run-vitest.ts run --project legacy",
    "test:modules": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file ./scripts/run-vitest.ts run --project modules",
    "test:run": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file ./scripts/run-vitest.ts run",
    "test:e2e": "playwright test",
    "test:ui-dom": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file ./scripts/run-vitest.ts run --project ui",
    "test:smoke:dev-auth": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file test ./tests/smoke/dev-auth-gate.test.ts",
    "test:smoke:bun-auth": "LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file run build && LOCAL_STREAMER_DISABLE_VITE_ENV_FILES=true bun --no-env-file test ./tests/smoke/bun-auth-gate.test.ts",
    "test:ui": "bun ./scripts/run-vitest.ts --ui",
    "typecheck": "react-router typegen && tsc",
    "ui:add": "bunx --bun shadcn@4.0.0 add"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "^7.7.1",
    "@vidstack/react": "^1.12.13",
    "argon2": "^0.43.1",
    "async-mutex": "^0.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dashjs": "^5.0.3",
    "hono": "^4.9.0",
    "isbot": "^5.1.27",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-router": "^7.7.1",
    "react-router-hono-server": "^2.20.0",
    "remix-utils": "^8.8.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.7.1",
    "@react-router/fs-routes": "^7.9.1",
    "@retn0/eslint-config": "^1.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.33.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.2.17"
}
