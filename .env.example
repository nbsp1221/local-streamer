# Auth configuration
AUTH_SHARED_PASSWORD=replace-with-a-strong-shared-password

# Optional config-owned owner identity
AUTH_OWNER_ID=site-owner
AUTH_OWNER_EMAIL=owner@local

# Optional auth session persistence path
AUTH_SQLITE_PATH=./storage/data/auth.sqlite

# Optional auth session lifetime in milliseconds
AUTH_SESSION_TTL_MS=604800000

# Generate a secure 64-character hex string for video encryption
VIDEO_MASTER_ENCRYPTION_SEED=your-64-char-hex-seed-here-replace-with-random-value-123456789

# Salt prefix for key derivation (security-related)
KEY_SALT_PREFIX=local-streamer-video-v1

# Generate a secure random string for JWT authentication
VIDEO_JWT_SECRET=your-secure-jwt-secret-key-here
